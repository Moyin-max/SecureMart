PORT=3000
APP_BASE_URL=http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

# Set a strong secret for protected write/payment endpoints.
SECUREMART_API_KEY=change-me-to-a-long-random-string

# Interswitch config
INTERSWITCH_MODE=sandbox
INTERSWITCH_MERCHANT_CODE=MX6072
INTERSWITCH_PAY_ITEM_ID=Default_Payable_MX6072
INTERSWITCH_SECRET_KEY=replace-with-interswitch-secret
INTERSWITCH_REDIRECT_URL=http://localhost:3000/

# Optional Passport/Marketplace credentials (if provided by Interswitch)
INTERSWITCH_CLIENT_ID=replace-with-client-id
INTERSWITCH_CLIENT_SECRET=replace-with-client-secret
INTERSWITCH_API_BASE_URL=https://api-marketplace-routing.interswitchng.com/marketplace-routing
INTERSWITCH_AUTH_BASE_URL=https://passport.interswitchng.com
INTERSWITCH_CARD_API_BASE_URL=https://qa.interswitchng.com
INTERSWITCH_CARD_DEMO_MODE=true
